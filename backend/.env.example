# Application
APP_NAME=BuildCore
APP_VERSION=0.1.0
DEBUG=false

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/buildcore

# JWT
JWT_SECRET_KEY=change-me-in-production-use-a-long-random-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Storage (MinIO)
STORAGE_NAME=minio
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=buildcore
STORAGE_REGION=us-east-1

# CORS
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# Super Admin (seed)
SUPER_ADMIN_EMAIL=superadmin@buildcore.com
SUPER_ADMIN_PASSWORD=SuperAdmin@123
